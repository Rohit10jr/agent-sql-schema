# ── Django ──────────────────────────────────────────────────────────
SECRET_KEY=replace-me-with-a-long-random-string
DEBUG=True

# ── Database (Postgres) ─────────────────────────────────────────────
POSTGRES_DB=agentsql
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/agentsql

# ── LLM keys ────────────────────────────────────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=

# ── OAuth (optional) ────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email ───────────────────────────────────────────────────────────
# To preview emails in the runserver console during development, uncomment:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Gmail SMTP (recommended for dev, ~500/day cap).
# 1. Enable 2-Step Verification on the Google account.
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Paste the 16-char code into EMAIL_HOST_PASSWORD (no spaces).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-account@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
EMAIL_TIMEOUT=20

# Sender shown to recipients. With Gmail SMTP, the From: address is rewritten
# to EMAIL_HOST_USER unless it's a verified "Send mail as" alias — but the
# display name (the part before <...>) is honored.
DEFAULT_FROM_EMAIL=Nao <your-account@gmail.com>

# Sender used when Django mails the ADMINS list (unhandled-error notifications
# and explicit mail_admins() calls). Defaults to DEFAULT_FROM_EMAIL.
SERVER_EMAIL=no-reply@yourdomain.com

# Comma-separated emails that receive admin error notifications.
DJANGO_ADMIN_EMAIL=

# Display name interpolated into transactional email templates.
EMAIL_SITE_NAME=Nao

# Frontend origin used to build the verification + password-reset URLs in
# email bodies. Override per environment (dev / staging / prod).
FRONTEND_URL=http://localhost:3000
